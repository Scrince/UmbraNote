#include "resource.h"
#include <windows.h>

IDR_MENU MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New\tCtrl+N",        IDM_FILE_NEW
        MENUITEM "&Open...\tCtrl+O",    IDM_FILE_OPEN
        MENUITEM "&Save\tCtrl+S",       IDM_FILE_SAVE
        MENUITEM "Save &As...",         IDM_FILE_SAVEAS
        MENUITEM "Save Encrypted &As...", IDM_FILE_SAVEENCRYPTED
        MENUITEM SEPARATOR
        MENUITEM "Export to &PDF...",   IDM_FILE_EXPORTPDF
        MENUITEM SEPARATOR
        MENUITEM "&Print...\tCtrl+P",  IDM_FILE_PRINT
        MENUITEM SEPARATOR
        MENUITEM "E&xit",               IDM_FILE_EXIT
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Undo\tCtrl+Z",       IDM_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "Cu&t\tCtrl+X",        IDM_EDIT_CUT
        MENUITEM "&Copy\tCtrl+C",       IDM_EDIT_COPY
        MENUITEM "&Paste\tCtrl+V",      IDM_EDIT_PASTE
        MENUITEM "De&lete\tDel",        IDM_EDIT_DELETE
        MENUITEM SEPARATOR
        MENUITEM "&Find...\tCtrl+F",    IDM_EDIT_FIND
        MENUITEM "Find &Next\tF3",      IDM_EDIT_FINDNEXT
        MENUITEM "&Replace...\tCtrl+H", IDM_EDIT_REPLACE
        MENUITEM "&Go To...\tCtrl+G",   IDM_EDIT_GOTO
        MENUITEM SEPARATOR
        MENUITEM "Select &All\tCtrl+A", IDM_EDIT_SELECTALL
    END
    POPUP "F&ormat"
    BEGIN
        MENUITEM "&Word Wrap",          IDM_FORMAT_WORDWRAP
        MENUITEM "&Font...",            IDM_FORMAT_FONT
    END
END

IDR_ACCEL ACCELERATORS
BEGIN
    "N", IDM_FILE_NEW, VIRTKEY, CONTROL
    "O", IDM_FILE_OPEN, VIRTKEY, CONTROL
    "S", IDM_FILE_SAVE, VIRTKEY, CONTROL
    "P", IDM_FILE_PRINT, VIRTKEY, CONTROL
    "Z", IDM_EDIT_UNDO, VIRTKEY, CONTROL
    "X", IDM_EDIT_CUT, VIRTKEY, CONTROL
    "C", IDM_EDIT_COPY, VIRTKEY, CONTROL
    "V", IDM_EDIT_PASTE, VIRTKEY, CONTROL
    "F", IDM_EDIT_FIND, VIRTKEY, CONTROL
    "H", IDM_EDIT_REPLACE, VIRTKEY, CONTROL
    "G", IDM_EDIT_GOTO, VIRTKEY, CONTROL
    "A", IDM_EDIT_SELECTALL, VIRTKEY, CONTROL
    VK_F3, IDM_EDIT_FINDNEXT, VIRTKEY
END

IDD_FIND DIALOGEX 0, 0, 260, 88
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Find"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Find what:", -1, 12, 14, 55, 10
    EDITTEXT IDC_FINDWHAT, 72, 12, 176, 16, ES_AUTOHSCROLL
    CONTROL "Match &case", IDC_MATCHCASE, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 72, 36, 90, 12
    DEFPUSHBUTTON "Find Next", IDOK, 72, 58, 64, 18
    PUSHBUTTON "Cancel", IDCANCEL, 142, 58, 64, 18
END

IDD_REPLACE DIALOGEX 0, 0, 280, 118
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Replace"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Find what:", -1, 12, 14, 55, 10
    EDITTEXT IDC_REPLACEWHAT, 72, 12, 196, 16, ES_AUTOHSCROLL
    LTEXT "Replace with:", -1, 12, 36, 55, 10
    EDITTEXT IDC_REPLACEWITH, 72, 34, 196, 16, ES_AUTOHSCROLL
    CONTROL "Match &case", IDC_MATCHCASE, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 72, 58, 90, 12
    PUSHBUTTON "&Replace", IDOK, 72, 84, 64, 18
    PUSHBUTTON "Replace &All", 1001, 142, 84, 70, 18
    PUSHBUTTON "Cancel", IDCANCEL, 218, 84, 64, 18
END

IDD_GOTO DIALOGEX 0, 0, 220, 82
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Go To Line"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "&Line number:", -1, 12, 16, 60, 10
    EDITTEXT IDC_GOTO_LINE, 76, 14, 132, 16, ES_NUMBER | ES_AUTOHSCROLL
    DEFPUSHBUTTON "OK", IDOK, 52, 48, 64, 18
    PUSHBUTTON "Cancel", IDCANCEL, 122, 48, 64, 18
END

IDD_PASSWORD DIALOGEX 0, 0, 360, 188
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Protect Note"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Password:", IDC_PASSWORD_LABEL, 12, 14, 50, 10
    EDITTEXT IDC_PASSWORD, 66, 12, 282, 16, ES_PASSWORD | ES_AUTOHSCROLL
    LTEXT "Confirm:", IDC_PASSWORD_CONFIRM_LABEL, 12, 38, 50, 10
    EDITTEXT IDC_PASSWORD_CONFIRM, 66, 36, 282, 16, ES_PASSWORD | ES_AUTOHSCROLL
    LTEXT "Keyfile:", IDC_KEYFILE_LABEL, 12, 62, 50, 10
    EDITTEXT IDC_KEYFILE_PATH, 66, 60, 216, 16, ES_AUTOHSCROLL | ES_READONLY
    PUSHBUTTON "Browse...", IDC_KEYFILE_BROWSE, 288, 60, 60, 16
    CONTROL "High-security mode (Argon2id + keyfile required)", IDC_PARANOID_KDF,
            "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 12, 86, 336, 12
    LTEXT "Uses XChaCha20-Poly1305, Argon2id, locked key memory, and re-auth on save.", -1, 12, 104, 336, 20
    DEFPUSHBUTTON "OK", IDOK, 118, 154, 64, 18
    PUSHBUTTON "Cancel", IDCANCEL, 188, 154, 64, 18
END
